# Copiá a la raíz del repo como `.env.compose` y usá:
#   docker compose --env-file .env.compose up --build
#
# MySQL del contenedor: root sin contraseña (solo desarrollo).
# Evitamos el puerto 3306 del host si ya tenés MySQL local → 3307 por defecto.
#
# Nuxt en Docker: copiá el paquete SproutKit a frontend/vendor/sproutkit-vue (ver frontend/package.json).
# El front usa NUXT_PUBLIC_API_BASE=http://host.docker.internal:${APP_PUBLISH_PORT} (definido en docker-compose).

DB_DATABASE=challenge
DB_USERNAME=root
DB_PASSWORD=

MYSQL_PUBLISH_PORT=3307
APP_PUBLISH_PORT=8000
FRONT_PUBLISH_PORT=3000
REVERB_PUBLISH_PORT=8081

APP_URL=http://127.0.0.1:8000

REVERB_APP_ID=1001
REVERB_APP_KEY=challenge-local-key
REVERB_APP_SECRET=challenge-local-secret

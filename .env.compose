# Copiá desde docker/compose.env.example si no existe.
#   docker compose --env-file .env.compose up --build
#
# MySQL (Docker): root sin contraseña — no hace falta DB_PASSWORD.
# SproutKit: frontend/vendor/sproutkit-vue

DB_DATABASE=challenge
DB_USERNAME=root
DB_PASSWORD=

MYSQL_PUBLISH_PORT=3307
APP_PUBLISH_PORT=8000
FRONT_PUBLISH_PORT=3000
REVERB_PUBLISH_PORT=8081

APP_URL=http://127.0.0.1:8000

REVERB_APP_ID=1001
REVERB_APP_KEY=challenge-local-key
REVERB_APP_SECRET=challenge-local-secret

# Debe coincidir con backend/.env → REVERB_APP_KEY / REVERB_HOST / REVERB_PORT / REVERB_SCHEME
# Si no definís nada, Nuxt usa los mismos valores por defecto que el backend en config/reverb.php
NUXT_PUBLIC_REVERB_APP_KEY=challenge-local-key
NUXT_PUBLIC_REVERB_HOST=127.0.0.1
NUXT_PUBLIC_REVERB_PORT=8081
NUXT_PUBLIC_REVERB_SCHEME=http

# API Laravel (proxy Nuxt → backend)
NUXT_PUBLIC_API_BASE=http://127.0.0.1:8000
